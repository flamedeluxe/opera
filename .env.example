HTTP_PORT=18080
TZ=UTC

# Подробный вывод ошибок PHP в браузере (только разработка). В .settings.php читается как getenv('BITRIX_DEBUG').
# BITRIX_DEBUG=1

# Установщик Битрикс: сервер БД = db (сервис docker-compose), логин/пароль = MYSQL_USER / MYSQL_PASSWORD.
MYSQL_ROOT_PASSWORD=change_me
MYSQL_DATABASE=bitrix
MYSQL_USER=bitrix
MYSQL_PASSWORD=change_me

# Отдельная схема WordPress после импорта wp-old/*.sql (MariaDB-сервис db).
WP_IMPORT_DB_HOST=db
WP_IMPORT_DB_NAME=wordpress
WP_IMPORT_DB_USER=
WP_IMPORT_DB_PASSWORD=
WP_TABLE_PREFIX=wp_
